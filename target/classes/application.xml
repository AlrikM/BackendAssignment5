<!DOCTYPE beans PUBLIC "-//SPRING//DTD BEAN//EN"  
            "http://www.springframework.org/dtd/spring-beans-2.0.dtd">

<beans>
	<!-- add your bean definitions here! -->
	<bean id="dataSource" class="org.apache.commons.dbcp.BasicDataSource"
		  destroy-method="close">
		<property name= "driverClassName" value="org.hsqldb.jdbcDriver" />
		<property name= "url" value="jdbc:hsqldb:file:database.dat;shutdown=true" />
		<property name="username" value="sa"/>
		<property name="password" value="" />
	</bean>
	<bean id="jdbcTemplate"
		  class="org.springframework.jdbc.core.JdbcTemplate">
		<constructor-arg ref="dataSource" />
	</bean>
	<bean id="customerManagementMockImpl" class="se.yrgo.services.customers.CustomerManagementMockImpl">
		<constructor-arg ref="jdbcTemplate"/>
	</bean>
	<bean id="diaryManagementServiceMockImpl" class="se.yrgo.services.diary.DiaryManagementServiceMockImpl"/>
	<bean id="callHandlingServiceImpl" class="se.yrgo.services.calls.CallHandlingServiceImpl">
		<constructor-arg ref="customerManagementMockImpl"/>
		<constructor-arg ref="diaryManagementServiceMockImpl"/>
	</bean>
</beans>
