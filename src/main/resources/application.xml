<beans xmlns="http://www.springframework.org/schema/beans"
	   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	   xmlns:aop="http://www.springframework.org/schema/aop"
	   xsi:schemaLocation="http://www.springframework.org/schema/aop
				http://www.springframework.org/schema/aop/spring-aop.xsd
				http://www.springframework.org/schema/beans
				http://www.springframework.org/schema/beans/spring-beans.xsd">
	<!-- add your bean definitions here! -->
	<bean id="dataSource" class="org.apache.commons.dbcp.BasicDataSource"
		  destroy-method="close">
		<property name= "driverClassName" value="org.hsqldb.jdbcDriver" />
		<property name= "url" value="jdbc:hsqldb:file:database.dat;shutdown=true" />
		<property name="username" value="sa"/>
		<property name="password" value="" />
	</bean>
	<bean id="performanceTimingAdvice"
		  class="se.yrgo.advice.PerformanceTimingAdvice"/>
	<aop:config>
		<aop:aspect ref = "performanceTimingAdvice">
			<aop:around method="performTimingMeasurement"
						pointcut = "execution (* se.yrgo.services..*.* (..)) || execution (* se.yrgo.dataaccess.*.* (..))" />
		</aop:aspect>
	</aop:config>
	<bean id="jdbcTemplate" class="org.springframework.jdbc.core.JdbcTemplate">
		<constructor-arg ref="dataSource"/>
	</bean>
	<bean id="customerDao" class="se.yrgo.dataaccess.CustomerDaoJdbcTemplateImpl">
		<constructor-arg ref="jdbcTemplate"/>
	</bean>
	<bean id="customerManagementServiceProductionImpl" class="se.yrgo.services.customers.CustomerManagementServiceProductionImpl">
		<constructor-arg ref="customerDao"/>
	</bean>
	<bean id="diaryManagementServiceMockImpl" class="se.yrgo.services.diary.DiaryManagementServiceMockImpl"/>
	<bean id="callHandlingServiceImpl" class="se.yrgo.services.calls.CallHandlingServiceImpl">
		<constructor-arg ref="customerManagementServiceProductionImpl"/>
		<constructor-arg ref="diaryManagementServiceMockImpl"/>
	</bean>
</beans>
